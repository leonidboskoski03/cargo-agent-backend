# App/runtime
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Database (docker-compose + Prisma)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cargo_agent
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cargo_agent

# Auth/session
JWT_ACCESS_SECRET=replace_with_strong_access_secret_min_16_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_COOKIE_NAME=ca_access_token
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret_min_16_chars
JWT_REFRESH_COOKIE_NAME=ca_refresh_token
JWT_REFRESH_SESSION_DAYS=30
AUTH_LOGIN_MFA_REQUIRED_ROLES=COMPANY_ADMIN
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000
AUTH_LOGIN_RATE_LIMIT_MAX=20
AUTH_FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MS=60000
AUTH_FORGOT_PASSWORD_RATE_LIMIT_MAX=10
AUTH_RESET_PASSWORD_RATE_LIMIT_WINDOW_MS=60000
AUTH_RESET_PASSWORD_RATE_LIMIT_MAX=10
AUTH_STRICT_SESSION_CHECK_ENABLED=false
AUTH_RESET_PASSWORD_BIND_IP=false
AUTH_RESET_PASSWORD_BIND_USER_AGENT=false

# OTP
AUTH_OTP_PROVIDER=simulated
AUTH_OTP_CODE_LENGTH=6
AUTH_OTP_TTL_MINUTES=10
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_PREVIEW_IN_NON_PROD=true
AUTH_OTP_REQUEST_RATE_LIMIT_WINDOW_MS=60000
AUTH_OTP_REQUEST_RATE_LIMIT_MAX=12
AUTH_OTP_VERIFY_RATE_LIMIT_WINDOW_MS=60000
AUTH_OTP_VERIFY_RATE_LIMIT_MAX=30

# Invites
INVITE_ACCEPT_URL_BASE=http://localhost:3000/invites/accept

# Delivery provider readiness
EMAIL_PROVIDER=simulated
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Billing/Stripe (leave blank if Stripe flows are not enabled locally)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/billing/cancel
STRIPE_COMPANY_CREDITS_SUCCESS_URL=http://localhost:5173/company-credits/checkout/{CHECKOUT_SESSION_ID}
STRIPE_COMPANY_CREDITS_CANCEL_URL=http://localhost:5173/company-credits?checkout=canceled
STRIPE_JOB_WALLET_SUCCESS_URL=http://localhost:5173/job-wallet/checkout/{CHECKOUT_SESSION_ID}
STRIPE_JOB_WALLET_CANCEL_URL=http://localhost:5173/job-wallet?checkout=canceled
BILLING_PORTAL_RETURN_URL=http://localhost:5173/billing
# Job seeker and company credit-pack Stripe price IDs are stored on seeded DB records:
# JobSeekerCreditPack.stripePriceId and CompanyCreditPack.stripePriceId.
# Run `npm run stripe:sandbox:check` to see which plan/pack price IDs are still missing.

# Route estimation (OpenRouteService driving-hgv)
OPENROUTESERVICE_API_KEY=

# Upload storage
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads
UPLOAD_PUBLIC_BASE_URL=http://localhost:4000/uploads
UPLOAD_MAX_BYTES=5242880
UPLOAD_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,application/pdf
# S3 config is reserved for the later S3-compatible adapter.
# Current upload transport supports local storage; STORAGE_PROVIDER=s3 returns 501 until adapter implementation.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Redis/BullMQ
REDIS_URL=redis://127.0.0.1:6379
# Set false only if running API without queue consumers in local/dev scenarios.
BULLMQ_ENABLED=true

# Job seeker billing
JOB_SEEKER_FREE_APPLICATIONS_PER_MONTH=10
JOB_SEEKER_FREE_ACTIVE_LISTINGS=1
JOB_SEEKER_FREE_VEHICLE_LISTINGS_PER_MONTH=1
JOB_SEEKER_APPLICATION_CREDIT_COST=1
JOB_SEEKER_LISTING_PUBLISH_CREDIT_COST=2
JOB_SEEKER_VEHICLE_LISTING_CREDIT_COST=3
JOB_SEEKER_LISTING_PROMOTION_CREDIT_COST=2
JOB_SEEKER_SUBMISSION_PROMOTION_CREDIT_COST=1

# Company marketplace credits
COMPANY_JOB_POSTS_FREE_MONTHLY=3
COMPANY_VEHICLE_LISTINGS_FREE_MONTHLY=1
COMPANY_JOB_POST_CREDIT_COST=2
COMPANY_TRANSPORT_POST_CREDIT_COST=2
COMPANY_VEHICLE_LISTING_CREDIT_COST=3
COMPANY_POST_BOOST_CREDIT_COST=2
MARKETPLACE_BOOST_DURATION_DAYS=7

# Feature flags
INTERNAL_ADMIN_ADJUSTMENTS_ENABLED=false
# Staging cleanup/reconciliation cron jobs; disable only when another scheduler owns them.
CRON_ENABLED=true

