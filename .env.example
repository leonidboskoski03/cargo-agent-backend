NODE_ENV=development
PORT=4000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cargo_agent
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cargo_agent

JWT_ACCESS_SECRET=replace_with_strong_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_COOKIE_NAME=ca_access_token
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000
AUTH_LOGIN_RATE_LIMIT_MAX=20
AUTH_FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MS=60000
AUTH_FORGOT_PASSWORD_RATE_LIMIT_MAX=10
AUTH_RESET_PASSWORD_RATE_LIMIT_WINDOW_MS=60000
AUTH_RESET_PASSWORD_RATE_LIMIT_MAX=10
REDIS_URL=redis://localhost:6379
BULLMQ_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/billing/cancel
BILLING_PORTAL_RETURN_URL=http://localhost:3000/settings/billing
CRON_ENABLED=true

