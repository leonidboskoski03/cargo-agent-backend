{
  "name": "cargo-agent-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "dev:tsx": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:stack": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-stack.ps1",
    "dev:stack:no-stripe": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-stack.ps1 -SkipStripe",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:ci:unit": "vitest run --bail=1 tests/unit",
    "test:ci:integration": "vitest run --maxWorkers=1 --bail=1 tests/integration",
    "test:release": "vitest run tests/integration/releaseSmokeChain.spec.ts tests/integration/marketplaceEndToEnd.spec.ts tests/integration/billingWebhookLifecycle.spec.ts tests/integration/authOtpFlows.spec.ts tests/integration/stagingHardening.spec.ts",
    "test:release:ci": "vitest run --maxWorkers=1 --bail=1 tests/integration/releaseSmokeChain.spec.ts tests/integration/marketplaceEndToEnd.spec.ts tests/integration/billingWebhookLifecycle.spec.ts tests/integration/authOtpFlows.spec.ts tests/integration/stagingHardening.spec.ts",
    "test:evidence:webhooks": "vitest run --maxWorkers=1 --bail=1 tests/integration/billingWebhookLifecycle.spec.ts tests/integration/subscriptionWebhookLifecycle.spec.ts tests/integration/jobSeekerWebhookIdempotency.spec.ts",
    "test:evidence:contracts": "vitest run --maxWorkers=1 --bail=1 tests/integration/apiSmoke.spec.ts tests/integration/marketplaceEndToEnd.spec.ts tests/integration/releaseSmokeChain.spec.ts",
    "stripe:sandbox:check": "tsx scripts/stripe-sandbox-check.ts",
    "stripe:sandbox:bootstrap": "tsx scripts/stripe-sandbox-bootstrap.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f redis postgres",
    "prisma:generate": "prisma generate --schema prisma/schema",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio --schema prisma/schema",
    "prisma:validate": "prisma validate --schema prisma/schema",
    "ci:prisma": "npm run prisma:validate && npm run prisma:generate"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.58.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.0.5",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "stripe": "^18.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.14",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.5.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
